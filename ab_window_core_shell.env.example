# Example config for ab_window_core_shell.sh
#
# Copy and edit:
#   cp ab_window_core_shell.env.example ab_window_core_shell.env

SAMPLE_ID=sample1
FORCE=0

# Final A/B branch FASTA files, usually produced by ragtag_project.sh.
REF_A_FASTA=/path/to/refA_branch/ragtag.scaffold.fasta
REF_B_FASTA=/path/to/refB_branch/ragtag.scaffold.fasta

# Callable BED files in the same coordinates as REF_A_FASTA and REF_B_FASTA.
# These are usually produced by run_callable_assembly.sh after remapping reads
# with map_for_callable.sh.
REF_A_CALLABLE_BED=/path/to/results/callable_assembly/sample_refA/bed/sample_refA.callable.bed
REF_B_CALLABLE_BED=/path/to/results/callable_assembly/sample_refB/bed/sample_refB.callable.bed

REF_A_PROJECTION=sample_refA
REF_B_PROJECTION=sample_refB
REF_A_NAME=reference_A
REF_B_NAME=reference_B

# Regexes selecting the sequences/windows that define the primary coordinate
# comparison space. Use .* when the branch FASTA contains only primary scaffolds
# or chromosomes.
PRIMARY_REGEX_A=.*
PRIMARY_REGEX_B=.*

OUTDIR=/path/to/results/ab_window_core_shell
COMPARE_OUT=/path/to/results/ragtag_compare

WINDOW_SIZE=50000
WINDOW_MIN_OVERLAP_FRAC=0.5

THREADS=10
MINIMAP2_THREADS=10
MINIMAP2_PRESET=asm5

PYTHON_BIN=python3
SAMTOOLS=samtools
MINIMAP2=minimap2
