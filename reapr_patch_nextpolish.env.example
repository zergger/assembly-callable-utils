# Example config for reapr_patch_nextpolish.sh
#
# Copy and edit:
#   cp reapr_patch_nextpolish.env.example reapr_patch_nextpolish.env
#
# Run:
#   set -a && source reapr_patch_nextpolish.env && set +a
#   bash reapr_patch_nextpolish.sh

THREADS=10
REAPR_THREADS=10
RAGTAG_THREADS=10
SAMTOOLS_THREADS=1

PRIMARY_ASM=/path/to/primary.fasta
DONOR_ASM=/path/to/donor.fasta

R1=/path/to/reads_R1.fastq.gz
R2=/path/to/reads_R2.fastq.gz

WORKDIR=/path/to/work_reapr_patch_nextpolish
SAMPLE_ID=sample1
SEED=42

POLISHER=nextpolish

# Optional examples:
# DOWNSAMPLE_FRAC=1.0
# Reference projection is handled separately by ragtag_project.sh.
