# Example config for ragtag_project.sh
# Purpose: project one polished/unanchored assembly onto one reference with RagTag.

SAMPLE_TAG="sample_refA"
POLISHED_ASM="/path/to/polished_unanchored.fasta"
REFERENCE_ASM="/path/to/reference.fasta"
R1="/path/to/reads_R1.fastq.gz"
R2="/path/to/reads_R2.fastq.gz"
WORKDIR="/path/to/work_ragtag_project_sample_refA"

THREADS=10
RAGTAG_THREADS=10

# Primary paper-style branch: read-backed correction followed by scaffolding.
RUN_RAGTAG_CORRECT=1
RAGTAG_CORRECT_VALIDATE=1
RUN_RAGTAG_SCAFFOLD=1
RAGTAG_READTYPE="sr"
RAGTAG_READ_ALIGNER="minimap2"

# Tool resolution from PATH unless an absolute path is supplied.
RAGTAG_BIN="ragtag.py"
SAMTOOLS="samtools"

# Set FORCE=1 only when you intentionally want to remove and recompute
# existing correct/scaffold outputs inside WORKDIR.
FORCE=0
