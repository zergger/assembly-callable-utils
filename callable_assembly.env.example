# Example config for run_callable_assembly.sh
#
# Copy and edit:
#   cp callable_assembly.env.example callable_assembly.env

SAMPLE_TAG=sample1_refA
MODE=corrected_query_agp

FASTA=/path/to/ragtag.scaffold.fasta
BAM=/path/to/ragtag.correct.reads.s.bam
AGP=/path/to/ragtag.scaffold.agp

# Alternatively, provide a precomputed callable BED and omit BAM derivation.
# CALLABLE_BED=/path/to/callable.bed

OUTDIR=/path/to/results/callable_assembly/sample1_refA

MQ_CUTOFF=30

# Either set an explicit center and thresholds:
DEPTH_CENTER=79
DEPTH_LOW=39
DEPTH_HIGH=158

# Or comment the three lines above and rely on center derivation / multipliers.
# DEPTH_LOW_MULT=0.5
# DEPTH_HIGH_MULT=2.0

MASK_CHAR=N
OUTPUT_CALLABLE_ONLY=0
FORCE=0
