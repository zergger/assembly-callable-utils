# Example config for map_for_callable.sh
# Purpose: map reads back to one assembly FASTA and produce the BAM consumed by run_callable_assembly.sh.

SAMPLE_TAG="sample_refA_scaffold"
FASTA="/path/to/ragtag.scaffold.fasta"
READ1="/path/to/reads_R1.fastq.gz"
READ2="/path/to/reads_R2.fastq.gz"
OUTDIR="/path/to/results/callable_mapping/sample_refA_scaffold"
BAM_OUT="/path/to/results/callable_mapping/sample_refA_scaffold/map/sample_refA_scaffold.sorted.bam"

THREADS=10
ALIGNER="auto"  # auto|bwa-mem2|bwa

# Support summaries. Full depth TSVs are large; keep SAVE_DEPTH_TSV=0 by default.
RUN_FLAGSTAT=1
RUN_SAMTOOLS_STATS=1
RUN_DEPTH_SUMMARY=0
SAVE_DEPTH_TSV=0
DEPTH_MQ=0

# Tool resolution from PATH unless an absolute path is supplied.
SAMTOOLS="samtools"
BWA="bwa"
BWA_MEM2="bwa-mem2"
PYTHON_BIN="python3"

FORCE=0
