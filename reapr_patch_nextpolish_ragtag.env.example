# Example config for reapr_patch_nextpolish_ragtag.sh
#
# Copy and edit:
#   cp reapr_patch_nextpolish_ragtag.env.example reapr_patch_nextpolish_ragtag.env
#
# Run:
#   set -a && source reapr_patch_nextpolish_ragtag.env && set +a
#   bash reapr_patch_nextpolish_ragtag.sh

THREADS=10
REAPR_THREADS=10
RAGTAG_THREADS=10
SAMTOOLS_THREADS=1

PRIMARY_ASM=/path/to/primary.fasta
DONOR_ASM=/path/to/donor.fasta

R1=/path/to/reads_R1.fastq.gz
R2=/path/to/reads_R2.fastq.gz

# Optional: set to enable reference-guided correct/scaffold stages.
# REFERENCE_ASM=/path/to/reference.fasta

WORKDIR=/path/to/work_reapr_patch_nextpolish_ragtag
SAMPLE_ID=sample1
SEED=42

POLISHER=nextpolish
RUN_SORTNR=0

# Optional examples:
# DOWNSAMPLE_FRAC=1.0
# RUN_RAGTAG_CORRECT=1
# RAGTAG_READTYPE=sr
# RAGTAG_READ_ALIGNER=minimap2
